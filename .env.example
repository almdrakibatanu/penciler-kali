# ===== PencilerKali.com — environment configuration =====
# Copy this file to .env and fill in the values you have. Anything missing
# falls back to local/offline mode (no upload, dry-run publish, silent TTS).

NODE_ENV=development

# Database — SQLite is the zero-config default. Postgres URL switches drivers.
DATABASE_URL=file:./storage/data/penciler.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/penciler

# ----- AI rewriter (any one is enough; Anthropic is preferred) -----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
# Gemini is the actual rewriter. One key is enough; add more (from other Google
# accounts) for automatic fallback when a key's free-tier quota (429) is hit.
# Either comma-separate them here (GEMINI_API_KEY=key1,key2) or use the numbered
# slots below (GEMINI_API_KEY_2, _3, …). A key on 429 is skipped for 30 min.
GEMINI_API_KEY=
GEMINI_API_KEY_2=
# GEMINI_KEY_COOLDOWN_MS=1800000

# ----- pencil-cloud (Cloudinary clone) -----
# local | s3
PENCIL_CLOUD_DRIVER=local
PENCIL_CLOUD_BASE_URL=http://localhost:4000/cdn
PENCIL_CLOUD_SIGNING_SECRET=change-me-to-a-long-random-string
# Only for S3 driver:
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ----- pencil-voice (TTS clone) -----
# piper | sapi | espeak | silent
PENCIL_VOICE_ENGINE=sapi
# Path to a piper-tts binary + voice model (only if engine=piper)
PIPER_BIN=
PIPER_MODEL=
# SAPI on Windows: a Bangla voice name fragment. Leave empty for default.
SAPI_VOICE=Bangla

# ----- pencil-video -----
# ffmpeg-static is bundled; set this only to override.
FFMPEG_BIN=

# ----- Facebook publisher -----
# Page: https://www.facebook.com/profile.php?id=100066384905135
FACEBOOK_PAGE_ID=100066384905135
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_DRY_RUN=true

# ----- YouTube publisher -----
# Channel: https://www.youtube.com/@AMRWorld-gd2sl
YOUTUBE_CHANNEL_HANDLE=AMRWorld-gd2sl
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_DRY_RUN=true

# ----- Stock media -----
PEXELS_API_KEY=
PIXABAY_API_KEY=

# ----- Backend / scheduler -----
API_PORT=4000
WEB_PORT=3000
COLLECT_CRON=*/10 * * * *
REWRITE_CRON=*/15 * * * *
VIDEO_CRON=*/30 * * * *
PUBLISH_CRON=0 */1 * * *
